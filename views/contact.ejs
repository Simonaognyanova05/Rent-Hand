<!DOCTYPE html>
<html lang="bg">

<head>
    <%- include('./partials/header.ejs') %>
</head>

<body>

    <%- include('./partials/navbar.ejs') %>

        <section class="contact-page">

            <h1 class="page-title">Свържи се с нас</h1>

            <div class="contact-container">

                <!-- Contact Info -->
                <div class="contact-info">

                    <h2>Контактна информация</h2>

                    <div class="info-item">
                        <span>📍</span>
                        <p>София, България</p>
                    </div>

                    <div class="info-item">
                        <span>📞</span>
                        <p>+359 888 123 456</p>
                    </div>

                    <div class="info-item">
                        <span>📧</span>
                        <p>contact@renthand.com</p>
                    </div>

                    <div class="info-item">
                        <span>🕐</span>
                        <p>Понеделник - Петък / 09:00 - 18:00</p>
                    </div>

                    <div class="socials">
                        <a href="#">🌐</a>
                        <a href="#">📘</a>
                        <a href="#">📷</a>
                        <a href="#">🐦</a>
                    </div>

                </div>


                <!-- Contact Form -->
                <div class="contact-form">

                    <h2>Изпрати съобщение</h2>

                    <form action="/contact" method="POST">

                        <input type="text" name="name" placeholder="Вашето име" required>

                        <input type="email" name="email" placeholder="Вашият имейл" required>

                        <select name="subject">

                            <option value="">Избери тема</option>
                            <option>Въпрос за услуга</option>
                            <option>Технически проблем</option>
                            <option>Партньорство</option>
                            <option>Друго</option>

                        </select>

                        <textarea name="message" placeholder="Вашето съобщение..." rows="6" required></textarea>

                        <button class="btn">
                            Изпрати съобщение
                        </button>

                    </form>

                </div>

            </div>



            <!-- FAQ Section -->

            <div class="faq-section">

                <h2 class="section-title">Често задавани въпроси</h2>

                <div class="faq">

                    <div class="faq-item">
                        <h3>Как работи платформата?</h3>
                        <p>Потребителите могат да създават услуги и да резервират време директно през платформата.</p>
                    </div>

                    <div class="faq-item">
                        <h3>Безплатно ли е използването?</h3>
                        <p>Да, регистрацията и създаването на услуги е напълно безплатно.</p>
                    </div>

                    <div class="faq-item">
                        <h3>Как да стана доставчик на услуги?</h3>
                        <p>След регистрация можете да създадете услуга от вашия профил.</p>
                    </div>

                </div>

            </div>

        </section>

        <%- include('./partials/footer.ejs') %>

</body>

</html>