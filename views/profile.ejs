<!DOCTYPE html>
<html lang="bg">

<head>
    <%- include('./partials/header.ejs') %>
</head>

<body>

    <%- include('./partials/navbar.ejs') %>

        <section class="page">

            <!-- ================= СЪОБЩЕНИЯ (СОБСТВЕНИК) ================= -->

            <h1 class="page-title">Съобщения</h1>

            <% let hasMessages=false; %>

                <% services.forEach(service=> { %>

                    <% if(service.messages && service.messages.length> 0){
                        hasMessages = true; %>

                        <div class="card">

                            <h2>
                                <%= service.title %>
                            </h2>

                            <% service.messages.forEach(msg=> { %>

                                <div class="message-card">

                                    <p class="message-email">
                                        📧 <%= msg.email %>
                                    </p>

                                    <div class="conversation">

                                        <% if(msg.conversation){ %>

                                            <% msg.conversation.forEach(chat=> { %>

                                                <div class="chat <%= chat.sender %>">
                                                    <p>
                                                        <%= chat.message %>
                                                    </p>
                                                </div>

                                                <% }) %>

                                                    <% } %>

                                    </div>

                                    <form action="/reply/<%= service._id %>/<%= msg._id %>" method="POST">
                                        <input type="text" name="reply" placeholder="Отговор..." required>
                                        <button class="reply-btn">Отговори</button>
                                    </form>

                                </div>

                                <% }) %>

                        </div>

                        <% } %>

                            <% }) %>

                                <% if(!hasMessages){ %>

                                    <div class="empty-state">
                                        Нямате съобщения
                                    </div>

                                    <% } %>



                                        <!-- ================= МОИТЕ СЪОБЩЕНИЯ (КЛИЕНТ) ================= -->

                                        <h1 class="page-title">Моите съобщения</h1>

                                        <% let hasMyMessages=false; %>

                                            <% myMessages.forEach(service=> { %>

                                                <% service.messages.forEach(msg=> { %>

                                                    <% if(msg.userId==user._id){ hasMyMessages=true; %>

                                                        <div class="card">

                                                            <h2>
                                                                <%= service.title %>
                                                            </h2>

                                                            <div class="message-card">

                                                                <p class="message-email">
                                                                    📧 <%= msg.email %>
                                                                </p>

                                                                <div class="conversation">

                                                                    <% if(msg.conversation){ %>

                                                                        <% msg.conversation.forEach(chat=> { %>

                                                                            <div class="chat <%= chat.sender %>">
                                                                                <p>
                                                                                    <%= chat.message %>
                                                                                </p>
                                                                            </div>

                                                                            <% }) %>

                                                                                <% } %>

                                                                </div>

                                                            </div>

                                                        </div>

                                                        <% } %>

                                                            <% }) %>

                                                                <% }) %>

                                                                    <% if(!hasMyMessages){ %>

                                                                        <div class="empty-state">
                                                                            Нямате съобщения
                                                                        </div>

                                                                        <% } %>



                                                                            <!-- ================= МОИТЕ УСЛУГИ ================= -->

                                                                            <h1 class="page-title">Моите услуги</h1>

                                                                            <% if(services.length===0){ %>

                                                                                <div class="empty-state">
                                                                                    Нямате създадени услуги
                                                                                </div>

                                                                                <% } %>

                                                                                    <% services.forEach(service=> { %>

                                                                                        <div class="card">

                                                                                            <h2>
                                                                                                <%= service.title %>
                                                                                            </h2>

                                                                                            <% const
                                                                                                bookedTimes=service.availableTimes.filter(t=>
                                                                                                t.booked); %>

                                                                                                <%
                                                                                                    if(bookedTimes.length>
                                                                                                    0){ %>

                                                                                                    <div
                                                                                                        class="bookings">

                                                                                                        <%
                                                                                                            bookedTimes.forEach(time=>
                                                                                                            { %>

                                                                                                            <div
                                                                                                                class="booking-card">

                                                                                                                <p>📅
                                                                                                                    <%= new
                                                                                                                        Date(time.date).toLocaleDateString()
                                                                                                                        %>
                                                                                                                </p>

                                                                                                                <p>🕐
                                                                                                                    <%= new
                                                                                                                        Date(time.date).toLocaleTimeString([],
                                                                                                                        {
                                                                                                                        hour:'2-digit',
                                                                                                                        minute:'2-digit'
                                                                                                                        })
                                                                                                                        %>
                                                                                                                </p>

                                                                                                                <p>📧
                                                                                                                    <%= time.email
                                                                                                                        %>
                                                                                                                </p>

                                                                                                            </div>

                                                                                                            <% }) %>

                                                                                                    </div>

                                                                                                    <% } else { %>

                                                                                                        <div
                                                                                                            class="empty-state small">
                                                                                                            Няма
                                                                                                            резервации
                                                                                                            за тази
                                                                                                            услуга
                                                                                                        </div>

                                                                                                        <% } %>

                                                                                        </div>

                                                                                        <% }) %>



                                                                                            <!-- ================= МОИТЕ РЕЗЕРВАЦИИ ================= -->

                                                                                            <h1 class="page-title">Моите
                                                                                                резервации</h1>

                                                                                            <% let hasBookings=false; %>

                                                                                                <%
                                                                                                    bookings.forEach(service=>
                                                                                                    { %>

                                                                                                    <%
                                                                                                        service.availableTimes.forEach(time=>
                                                                                                        { %>

                                                                                                        <% if(time.userId==user._id){
                                                                                                            hasBookings=true;
                                                                                                            %>

                                                                                                            <div
                                                                                                                class="booking-card">

                                                                                                                <h3>
                                                                                                                    <%= service.title
                                                                                                                        %>
                                                                                                                </h3>

                                                                                                                <p>📅
                                                                                                                    <%= new
                                                                                                                        Date(time.date).toLocaleDateString()
                                                                                                                        %>
                                                                                                                </p>

                                                                                                                <p>🕐
                                                                                                                    <%= new
                                                                                                                        Date(time.date).toLocaleTimeString([],
                                                                                                                        {
                                                                                                                        hour:'2-digit',
                                                                                                                        minute:'2-digit'
                                                                                                                        })
                                                                                                                        %>
                                                                                                                </p>

                                                                                                                <p>📧
                                                                                                                    <%= time.email
                                                                                                                        %>
                                                                                                                </p>

                                                                                                            </div>

                                                                                                            <% } %>

                                                                                                                <% }) %>

                                                                                                                    <% })
                                                                                                                        %>

                                                                                                                        <% if(!hasBookings){
                                                                                                                            %>

                                                                                                                            <div
                                                                                                                                class="empty-state">
                                                                                                                                Нямате
                                                                                                                                направени
                                                                                                                                резервации
                                                                                                                            </div>

                                                                                                                            <% }
                                                                                                                                %>

        </section>

        <%- include('./partials/footer.ejs') %>

</body>

</html>