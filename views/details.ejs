<!DOCTYPE html>
<html lang="bg">

<head>
    <%- include('./partials/header.ejs') %>
</head>

<body>

    <%- include('./partials/navbar.ejs') %>

        <section class="details">

            <div class="details-card">

                <div class="details-image">
                    <img src="/images/service.jpg" alt="service">
                    <span class="category">Дизайн</span>
                </div>

                <div class="details-content">

                    <h1>
                        <%= service.title %>
                    </h1>

                    <div class="meta">
                        <span>⭐ 4.8</span>
                        <span>📍 <%= service.location %></span>
                        <span>⏱ 1 ден</span>
                    </div>

                    <p class="description">
                        <%= service.description %>
                    </p>

                    <div class="user">
                        <img src="/images/user1.jpg" class="avatar">
                        <div>
                            <p class="name">Иван Петров</p>
                            <p class="role">Продавач</p>
                        </div>
                    </div>

                    <div class="price-box">
                        <span class="price">
                            <%= service.price %> €
                        </span>
                        <button class="btn">Свържи се</button>
                    </div>

                    <a class="delete-btn" data-doc="<%= service._id %>">Delete</a>

                </div>

            </div>

        </section>

        <%- include('./partials/footer.ejs') %>

            <script>
                const trashkan = document.querySelector('a.delete-btn');

                trashkan.addEventListener('click', (e) => {
                    const endpoint = `/catalog/${trashkan.dataset.doc}`;

                    fetch(endpoint, {
                        method: 'DELETE'
                    })
                        .then(response => response.json())
                        .then(data => window.location.href = data.redirect)
                        .catch(e => console.log(e)
                        )
                })
            </script>

</body>

</html>