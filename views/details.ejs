<!DOCTYPE html>
<html lang="bg">

<head>
    <%- include('./partials/header.ejs') %>
</head>

<body>

    <%- include('./partials/navbar.ejs') %>

        <section class="details">

            <div class="details-card">

                <div class="details-image">
                    <img src="<%= service.img %>" alt="service">
                    <span class="category">Услуга</span>
                </div>

                <div class="details-content">

                    <h1>
                        <%= service.title %>
                    </h1>

                    <div class="meta">
                        <span>⭐ 4.8</span>
                        <span>📍 <%= service.location %></span>
                        <span>⏱ По договаряне</span>
                    </div>

                    <p class="description">
                        <%= service.description %>
                    </p>

                    <div class="user">
                        <div>
                            <p class="name">Продавач</p>
                            <p class="role">Собственик на услугата</p>
                        </div>
                    </div>

                    <div class="price-box">
                        <span class="price">
                            <%= service.price %> €
                        </span>

                        <button class="btn">Свържи се</button>
                    </div>


                    <!-- Свободни часове -->
                    <div class="available-times">

                        <h3>Свободни часове</h3>

                        <% if(service.availableTimes && service.availableTimes.length> 0){ %>

                            <div class="time-grid">

                                <% service.availableTimes.forEach(time=> { %>

                                    <% if(!time.booked){ %>

                                        <button class="time-card">

                                            <span class="date">
                                                <%= new Date(time.date).toLocaleDateString() %>
                                            </span>

                                            <span class="hour">
                                                <%= new Date(time.date).toLocaleTimeString([], {hour: '2-digit' ,
                                                    minute:'2-digit'}) %>
                                            </span>

                                        </button>

                                        <% } %>

                                            <% }) %>

                            </div>

                            <% } else { %>

                                <p>Няма налични часове</p>

                                <% } %>

                    </div>


                    <!-- Admin бутони -->
                    <% if (user && user._id.toString()===service.userId.toString()) { %>

                        <div class="owner-actions">

                            <a class="edit-btn btn" data-doc="<%= service._id %>">
                                Редактирай
                            </a>

                            <a class="delete-btn btn" data-doc="<%= service._id %>">
                                Изтрий
                            </a>

                        </div>

                        <% } %>

                </div>

            </div>

        </section>

        <%- include('./partials/footer.ejs') %>

            <script src="/js/deleteService.js"></script>

</body>

</html>