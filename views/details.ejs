<!DOCTYPE html>
<html lang="bg">

<head>
    <%- include('./partials/header.ejs') %>
</head>

<body data-user="<%= !!user %>">


    <%- include('./partials/navbar.ejs') %>

        <section class="details">

            <div class="details-card">

                <div class="details-image">
                    <img src="<%= service.img %>" alt="service">
                    <span class="category">Услуга</span>
                </div>

                <div class="details-content">

                    <h1>
                        <%= service.title %>
                    </h1>

                    <div class="meta">
                        <span>⭐ 4.8</span>
                        <span>📍 <%= service.location %></span>
                        <span>⏱ По договаряне</span>
                    </div>

                    <p class="description">
                        <%= service.description %>
                    </p>

                    <div class="user">
                        <div>
                            <p class="name">Продавач</p>
                            <p class="role">Собственик на услугата</p>
                        </div>
                    </div>

                    <div class="price-box">
                        <span class="price">
                            <%= service.price %> €
                        </span>

                        <button class="btn contact-btn">Свържи се</button>
                    </div>
                    <!-- Contact Modal -->
                    <div class="contact-modal hidden">

                        <div class="contact-box">

                            <h3>Свържи се със собственика</h3>

                            <form action="/messages/<%= service._id %>" method="POST">

                                <textarea name="message" placeholder="Напиши съобщение..." required></textarea>

                                <div class="contact-actions">

                                    <button class="send-btn">
                                        Изпрати
                                    </button>

                                    <button type="button" class="close-btn">
                                        Затвори
                                    </button>

                                </div>

                            </form>

                        </div>

                    </div>



                    <!-- Login Modal -->
                    <div class="login-modal hidden">

                        <div class="login-box">

                            <div class="login-icon">
                                🔒
                            </div>

                            <h3>Влез в профила си</h3>

                            <p class="login-text">
                                За да се свържеш със собственика на услугата трябва първо да влезеш в профила си
                            </p>

                            <div class="login-actions">

                                <a href="/login" class="login-btn primary">
                                    Вход
                                </a>

                                <a href="/register" class="login-btn secondary">
                                    Регистрация
                                </a>

                            </div>

                            <button type="button" class="close-login-btn close-login">
                                ✕
                            </button>

                        </div>

                    </div>

                    <!-- Свободни часове -->
                    <div class="available-times">

                        <h3>Свободни часове</h3>

                        <% if(service.availableTimes && service.availableTimes.length> 0){ %>

                            <div class="time-grid">

                                <% service.availableTimes.forEach(time=> { %>

                                    <% if(!time.booked){ %>

                                        <a href="/book/<%= service._id %>/<%= time._id %>" class="time-card book-btn">



                                            <span class="date">
                                                <%= new Date(time.date).toLocaleDateString() %>
                                            </span>

                                            <span class="hour">
                                                <%= new Date(time.date).toLocaleTimeString([], {hour: '2-digit' ,
                                                    minute:'2-digit'}) %>
                                            </span>

                                        </a>

                                        <% } %>

                                            <% }) %>

                            </div>

                            <% } else { %>

                                <p>Няма налични часове</p>

                                <% } %>

                    </div>


                    <!-- Admin бутони -->
                    <% if (user && user._id.toString()===service.userId.toString()) { %>

                        <div class="owner-actions">

                            <a class="edit-btn btn" data-doc="<%= service._id %>">
                                Редактирай
                            </a>

                            <a class="delete-btn btn" data-doc="<%= service._id %>">
                                Изтрий
                            </a>

                        </div>

                        <% } %>

                </div>

            </div>

        </section>

        <%- include('./partials/footer.ejs') %>


            <script src="/js/contactModal.js"></script>
            <script src="/js/deleteService.js"></script>
            <script src="/js/bookGuard.js"></script>


</body>

</html>